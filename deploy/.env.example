# Entorno del despliegue RAG

ENV=production
OLLAMA_BASE_URL=http://ollama:11434
# Si necesitas acceder desde el host, ajusta a http://localhost:11435
MODEL_NAME=qwen3:8b
TEMPERATURE=0.3
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_K=4
# Proveedor de LLM: 'ollama' (por defecto) u 'openai'
LLM_PROVIDER=ollama
DOCUMENTS_PATH=/data/markdown
VECTORSTORE_PATH=/data/vectorstore
LOG_PATH=/logs
# Ajusta esta variable para limitar la concurrencia si tu VPS lo requiere
MAX_CONCURRENT_SESSIONS=5

# Comma-separated list de IPs permitidas (ejemplo: "200.32.1.10,200.32.1.11"). Usa '*' para permitir todas.
ALLOWED_IPS=*

# Preguntas sugeridas para la interfaz de chat (separadas por '|')
EXAMPLE_QUESTIONS=¿Cuál es el horario de atención?|¿Qué promociones hay esta semana?|Quiero reservar una mesa

# Configuración para proxy inverso (si aplica)
# PROXY_BASIC_AUTH_USER=
# PROXY_BASIC_AUTH_PASSWORD=

# Prompt del sistema (opcional). Si no se define, usa el valor por defecto en el código.
# Recomendado: una sola línea. Si necesitás saltos de línea, usá \n para marcarlos.
# Ejemplo de una línea:
# SYSTEM_PROMPT=Eres un asistente para clientes. Responde solo con el contexto proporcionado.
# Ejemplo con "saltos de línea" usando \n:
# SYSTEM_PROMPT=Eres un asistente para clientes.\nUsa solo el contexto.\nSi no hay respuesta, indica que no sabes.

# OpenAI (si eliges LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# Para embeddings con OpenAI, define también el modelo de embeddings, por ejemplo:
# EMBEDDING_MODEL_NAME=text-embedding-3-small

# --- MCP Registry y ruteo dinámico ---
# Uno de los dos (prioridad para JSON embebido)
# MCP_REGISTRY_JSON=
# MCP_REGISTRY_PATH=/data/mcp/registry.json

# Tokens por proveedor MCP (ejemplos; deben coincidir con 'token_env' en el JSON)
# MCP_TOKEN_EVENTOS_DRF=token-aqui
# Agregá tantas variables MCP_TOKEN_* como proveedores declares
# MCP_TOKEN_OTRO_PROVEEDOR=token-b
# Token de producción para proveedor "teatro-bar" (scopes: events:read, health:read)
# MCP_TOKEN_TEATRO_BAR=

# (Opcional, futuro) CA privada para validar TLS de MCPs con certificados internos
# MCP_CA_BUNDLE=/etc/ssl/certs/ca-mcp.pem

# Zona horaria de la app y top-k para degradación FAISS (opcional)
# APP_TIMEZONE=UTC
# RAG_FAISS_TOPK=0
